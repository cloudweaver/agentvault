# AgentVault Environment Configuration

# =============================================================================
# LLM Providers
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-xxxxx
XAI_API_KEY=xai-xxxxx

# =============================================================================
# Solana Configuration
# =============================================================================
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
HELIUS_API_KEY=xxxxx
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=xxxxx

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/agentvault
REDIS_URL=redis://localhost:6379

# =============================================================================
# Frontend
# =============================================================================
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_PROGRAM_ID=AgVt1111111111111111111111111111111111111111

# =============================================================================
# Runtime
# =============================================================================
RUNTIME_PORT=3001
LOG_LEVEL=info
NODE_ENV=development

# =============================================================================
# Price Feeds
# =============================================================================
BIRDEYE_API_KEY=xxxxx
PYTH_PRICE_FEED_URL=https://hermes.pyth.network

# =============================================================================
# Notifications (Optional)
# =============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
