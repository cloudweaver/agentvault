# ==============================================================================
# AgentVault Environment Configuration
# ==============================================================================

# ------------------------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------------------------
NODE_ENV=development
RUNTIME_PORT=3001
LOG_LEVEL=info

# ------------------------------------------------------------------------------
# Solana Configuration
# ------------------------------------------------------------------------------
# Use Helius for enhanced RPC features (webhooks, DAS API)
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
HELIUS_API_KEY=your_helius_api_key

# Program ID (use default for devnet testing)
NEXT_PUBLIC_PROGRAM_ID=AgVt1111111111111111111111111111111111111111

# ------------------------------------------------------------------------------
# LLM Providers
# ------------------------------------------------------------------------------
# Anthropic Claude (required)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# xAI Grok (optional - fallback)
XAI_API_KEY=xai-your_xai_api_key

# ------------------------------------------------------------------------------
# Database Configuration
# ------------------------------------------------------------------------------
# PostgreSQL for persistent storage
DATABASE_URL=postgresql://user:password@localhost:5432/agentvault

# Redis for caching and sessions
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------------------------
# Price Feeds
# ------------------------------------------------------------------------------
# Birdeye API (optional - backup price source)
BIRDEYE_API_KEY=your_birdeye_api_key

# Pyth Network (optional)
PYTH_PRICE_FEED_URL=https://hermes.pyth.network

# ------------------------------------------------------------------------------
# Monitoring
# ------------------------------------------------------------------------------
# Background monitoring loop interval (ms)
MONITORING_INTERVAL_MS=30000

# ------------------------------------------------------------------------------
# Frontend Configuration (for app/)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_RUNTIME_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3002
NEXT_PUBLIC_SOLANA_NETWORK=devnet
