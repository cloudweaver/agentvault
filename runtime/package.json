{
  "name": "@agentvault/runtime",
  "version": "0.1.0",
  "description": "AgentVault Agent Runtime - LLM-powered autonomous execution engine",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "migrate": "tsx src/db/migrate.ts up",
    "migrate:status": "tsx src/db/migrate.ts status"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@coral-xyz/anchor": "^0.32.0",
    "@solana/web3.js": "^1.95.0",
    "@solana/spl-token": "^0.4.0",
    "bs58": "^5.0.0",
    "dotenv": "^16.4.0",
    "ioredis": "^5.4.0",
    "pg": "^8.13.0",
    "pino": "^9.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
